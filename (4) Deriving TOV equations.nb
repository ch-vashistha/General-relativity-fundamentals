Cell[TextData[{
 "Since field equations are derived by imposing that the variation in action \
is zero, we can simplify our expression by multiplying with factor of ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"-", "1"}], 
   SqrtBox[
    RowBox[{"-", 
     InterpretationBox[
      StyleBox["g",
