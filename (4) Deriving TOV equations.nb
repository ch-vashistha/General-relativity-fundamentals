Cell[TextData[{
 "Syntax to generate MaTeX formatted numbered equations:  ",
 StyleBox["\[OpenCurlyDoubleQuote]<expression>  \\qquad   <equation_number> \
\[OpenCurlyDoubleQuote] // mt",
  FontWeight->"Bold"],
 "\nExecute the above in an input cell, and then paste result in a text cell. "
}], "Text",
 CellChangeTimes->{{3.9444053174058104`*^9, 3.9444054315288277`*^9}, {
